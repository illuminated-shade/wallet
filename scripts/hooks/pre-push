#!/usr/bin/env bash
set -euo pipefail

zero_commit="0000000000000000000000000000000000000000"
needs_check=0

while read -r local_ref local_sha remote_ref remote_sha; do
  if [ -z "${local_sha:-}" ]; then
    continue
  fi

  if [ "$remote_sha" = "$zero_commit" ]; then
    range="$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi

  if git diff --name-only "$range" | rg -q '^apps/extension/'; then
    needs_check=1
    break
  fi
done

if [ "$needs_check" -eq 0 ]; then
  exit 0
fi

echo "[pre-push] Detected changes under apps/extension, running TypeScript check..."
(
  cd apps/extension
  tsc --noEmit
)
echo "[pre-push] TypeScript check passed."
